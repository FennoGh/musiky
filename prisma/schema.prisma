// Musiky — Database Schema
// "Music made together, paid apart."
//
// Stack: PostgreSQL + Prisma. Decimal columns for money, transactional payouts,
// eIDAS-compliant signature audit fields, full activity log.

datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client-js"
}

// ─── Auth & Billing ──────────────────────────────────────────────

enum Plan {
  STARTER
  PRO
  TEAM
}

model User {
  id           String    @id @default(cuid())
  email        String    @unique
  name         String?
  passwordHash String?
  image        String?
  plan         Plan      @default(STARTER)
  createdAt    DateTime  @default(now())

  ownedProjects   Project[]      @relation("ProjectOwner")
  collaborations  Collaborator[]
  expensesPaid    Expense[]      @relation("ExpensePayer")
  payoutsReceived Payout[]
  activities      Activity[]
}

// ─── Projects & Tracks ───────────────────────────────────────────

enum ProjectStatus {
  DRAFT
  READY
  LIVE
  ARCHIVED
}

model Project {
  id         String        @id @default(cuid())
  title      String
  coverUrl   String?
  status     ProjectStatus @default(DRAFT)
  ownerId    String
  owner      User          @relation("ProjectOwner", fields: [ownerId], references: [id])
  createdAt  DateTime      @default(now())
  releasedAt DateTime?

  collaborators Collaborator[]
  tracks        Track[]
  expenses      Expense[]
  revenues      Revenue[]
  distributions Distribution[]
  activities    Activity[]
  payouts       Payout[]

  @@index([ownerId])
}

model Track {
  id         String   @id @default(cuid())
  projectId  String
  project    Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  title      String
  fileUrl    String // S3 / Supabase storage key
  coverUrl   String? // optional artwork for the track
  version    Int      @default(1)
  duration   Int? // seconds
  uploadedAt DateTime @default(now())

  @@index([projectId])
}

// ─── Collaborators & Splits ──────────────────────────────────────

enum CollabRole {
  OWNER
  PRODUCER
  COMPOSER
  VOCALIST
  MANAGER
  ARTIST
  OTHER
}

model Collaborator {
  id        String     @id @default(cuid())
  projectId String
  project   Project    @relation(fields: [projectId], references: [id], onDelete: Cascade)
  userId    String
  user      User       @relation(fields: [userId], references: [id])
  role      CollabRole
  splitPct  Decimal    @db.Decimal(5, 2) // e.g. 40.00
  joinedAt  DateTime   @default(now())

  @@unique([projectId, userId])
  @@index([projectId])
}

// ─── Expenses ────────────────────────────────────────────────────

enum ExpenseCategory {
  MARKETING
  PRODUCTION
  MASTERING
  VIDEO
  LEGAL
  OTHER
}

model Expense {
  id          String          @id @default(cuid())
  projectId   String
  project     Project         @relation(fields: [projectId], references: [id], onDelete: Cascade)
  payerId     String
  payer       User            @relation("ExpensePayer", fields: [payerId], references: [id])
  category    ExpenseCategory
  amount      Decimal         @db.Decimal(12, 2)
  currency    String          @default("USD")
  description String?
  spentAt     DateTime        @default(now())

  @@index([projectId])
}

// ─── Distribution & Platforms ────────────────────────────────────

enum DistStatus {
  PENDING
  LIVE
}

model Platform {
  id      String  @id @default(cuid())
  name    String  @unique // "Spotify", "Apple Music", ...
  slug    String  @unique

  distributions Distribution[]
  revenues      Revenue[]
}

model Distribution {
  id         String     @id @default(cuid())
  projectId  String
  project    Project    @relation(fields: [projectId], references: [id], onDelete: Cascade)
  platformId String
  platform   Platform   @relation(fields: [platformId], references: [id])
  status     DistStatus @default(PENDING)
  liveAt     DateTime?
  streams    Int        @default(0)

  @@unique([projectId, platformId])
}

// ─── Revenue & Payouts ───────────────────────────────────────────

model Revenue {
  id          String   @id @default(cuid())
  projectId   String
  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  platformId  String
  platform    Platform @relation(fields: [platformId], references: [id])
  amount      Decimal  @db.Decimal(12, 2)
  currency    String   @default("USD")
  periodStart DateTime
  periodEnd   DateTime
  receivedAt  DateTime @default(now())

  payouts Payout[]

  @@index([projectId, receivedAt])
}

enum PayoutStatus {
  PENDING
  PAID
}

model Payout {
  id        String       @id @default(cuid())
  projectId String
  project   Project      @relation(fields: [projectId], references: [id])
  revenueId String
  revenue   Revenue      @relation(fields: [revenueId], references: [id])
  userId    String
  user      User         @relation(fields: [userId], references: [id])
  amount    Decimal      @db.Decimal(12, 2)
  status    PayoutStatus @default(PENDING)
  paidAt    DateTime?

  @@index([userId, status])
  @@index([projectId])
}

// ─── Activity Feed (audit log) ───────────────────────────────────

enum ActivityType {
  PROJECT_CREATED
  TRACK_UPLOADED
  COLLAB_JOINED
  DISTRIBUTED
  EXPENSE_LOGGED
  REVENUE_RECEIVED
  PAYOUT_SENT
}

model Activity {
  id        String       @id @default(cuid())
  projectId String?
  project   Project?     @relation(fields: [projectId], references: [id], onDelete: Cascade)
  actorId   String?
  actor     User?        @relation(fields: [actorId], references: [id])
  type      ActivityType
  payload   Json? // flexible details: amounts, names, platform ids, ...
  createdAt DateTime     @default(now())

  @@index([projectId, createdAt])
}
