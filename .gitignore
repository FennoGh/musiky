# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# Node deps & Next build
node_modules/
.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions
frontend/.next/
frontend/out/
frontend/build/

# testing
/coverage

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
frontend/next-env.d.ts

# runtime uploads (local dev) — keep folders, ignore contents
backend/uploads/covers/*
backend/uploads/audio/*
!backend/uploads/covers/.gitkeep
!backend/uploads/audio/.gitkeep
.dev-mobile-last-ip

# Python backend
backend/.venv/
backend/staticfiles/
__pycache__/
*.py[cod]
*.egg-info/

# Android / Capacitor build artifacts
/android/.gradle/
/android/build/
/android/app/build/
/android/captures/
/android/local.properties
/android/.idea/
/android/app/release/
*.keystore

# IDE / editor metadata
/.idea/
/.vscode/
*.iml
