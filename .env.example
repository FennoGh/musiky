# ── Database ──────────────────────────────────────────────────────
# Used by Django (backend/) and docker-compose's db service.
DATABASE_URL=postgres://musiky:CHANGE_ME@localhost:5432/musiky

# Shared password — must match DATABASE_URL above.
DB_PASSWORD=CHANGE_ME

# ── Django ────────────────────────────────────────────────────────
# Generate a secure secret: openssl rand -hex 32
DJANGO_SECRET_KEY=CHANGE_ME_use_openssl_rand_hex_32
DJANGO_DEBUG=False
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,174.138.1.11

# ── JWT (DRF SimpleJWT) ───────────────────────────────────────────
JWT_SECRET=CHANGE_ME_use_openssl_rand_hex_32
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# ── Web (Next.js) ─────────────────────────────────────────────────
# Public variable — visible to the browser. Set to your server's IP or domain.
NEXT_PUBLIC_API_BASE=http://174.138.1.11:8000

# ── Server ───────────────────────────────────────────────────────
# IP or hostname of the production server (used by deploy.sh)
SERVER_IP=174.138.1.11
