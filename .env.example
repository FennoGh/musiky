# ── Database ──────────────────────────────────────────────────────
# Used by Prisma (Next.js migrations and seed)
DATABASE_URL="postgresql://musiky:CHANGE_ME@localhost:5432/musiky?schema=public"

# Shared password — must match DATABASE_URL above
# Used by docker-compose.yml for the db service and api service
DB_PASSWORD=CHANGE_ME

# ── API (FastAPI) ─────────────────────────────────────────────────
# Generate a secure secret: openssl rand -hex 32
JWT_SECRET=CHANGE_ME_use_openssl_rand_hex_32
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# ── Web (Next.js) ─────────────────────────────────────────────────
# Public variable — visible to the browser. Set to your server's IP or domain.
NEXT_PUBLIC_API_BASE=http://174.138.1.11:8000

# ── Server ───────────────────────────────────────────────────────
# IP or hostname of the production server (used by deploy.sh)
SERVER_IP=174.138.1.11
